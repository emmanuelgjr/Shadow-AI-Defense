---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).map((s) => s.data);
const groups = Array.from(new Set(services.map((s) => s.category))).sort();

const tierColor = (t: string) =>
  t === 'Block' ? 'bg-risk-50 text-risk-700'
  : t === 'Allow Enterprise' ? 'bg-ok-50 text-ok-700'
  : t === 'Allow with DLP' ? 'bg-info-50 text-info-700'
  : 'bg-warn-50 text-warn-700';
---

<BaseLayout
  title="AI Services Catalog — Shadow AI Defense"
  description={`${services.length} AI services cataloged with network signatures, client signatures, risk profile, and applicable detection rules.`}
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <p class="text-sm font-medium text-accent-700">Services</p>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">
      {services.length} AI services cataloged
    </h1>
    <p class="mt-3 text-ink-600 max-w-prose-wide">
      Each service entry includes domains, API endpoints, browser-extension IDs,
      desktop/mobile app identifiers, default training-on-data behavior, and
      recommended response tier.
    </p>

    {groups.map((g) => (
      <div class="mt-12">
        <h2 class="font-display font-semibold text-2xl text-ink-900 tracking-tight">{g}</h2>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-4">
          {services.filter((s) => s.category === g).map((s) => (
            <li>
              <a href={`/services/${s.slug}`} class="card-interactive block h-full">
                <div class="flex items-start justify-between gap-2 mb-1">
                  <h3 class="font-semibold text-ink-900">{s.name}</h3>
                  <span class={`badge ${tierColor(s.recommended_response)}`}>{s.recommended_response}</span>
                </div>
                <p class="text-xs text-ink-500">{s.vendor}</p>
                <p class="text-sm text-ink-600 mt-2 line-clamp-2">{s.data_egress_concerns[0]}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
