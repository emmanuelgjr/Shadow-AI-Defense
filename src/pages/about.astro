---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Emmanuel Guilherme Jr.',
  url: 'https://github.com/emmanuelgjr',
  sameAs: ['https://www.linkedin.com/in/emmanuelgjr/', 'https://genai.owasp.org/'],
};
---

<BaseLayout
  title="About — Shadow AI Defense"
  description="About the author. Proposed the Shadow AI / DLP control at a Tier 1 multinational."
  structuredData={structuredData}
>
  <section class="max-w-3xl mx-auto px-6 lg:px-8 py-12">
    <p class="text-sm font-medium text-accent-700">About</p>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">About the author</h1>

    <div class="prose prose-lg max-w-prose-wide mt-8">
      <p>
        <strong>Emmanuel Guilherme Jr.</strong> is a Senior Global Information
        Technology Auditor and AI security researcher based in Toronto, Canada.
      </p>
      <p>
        He co-leads the Data Security Initiative of the
        <strong>OWASP GenAI Security Project</strong>. He serves as a
        <strong>Candidate Expert</strong> on Canada's mirror committee for
        ISO/IEC JTC 1/SC 42.
      </p>
      <p>
        He proposed the exact Shadow AI / DLP control implemented at a Tier 1
        global multinational on a Microsoft-centric stack (Defender, Purview,
        Sentinel) plus CrowdStrike. This repo is the generalized, public
        version of that work.
      </p>
      <p>
        Find him at
        <a href="https://www.linkedin.com/in/emmanuelgjr/">LinkedIn</a> ·
        <a href="https://github.com/emmanuelgjr">GitHub</a>.
      </p>
      <h2>Cite this work</h2>
      <p class="font-mono text-sm">Guilherme Jr., E. (2026). Shadow AI Defense (Version 0.1.0). https://shadowaidefense.dev</p>
    </div>
  </section>
</BaseLayout>
