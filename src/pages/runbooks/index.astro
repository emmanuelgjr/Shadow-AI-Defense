---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const runbooks = (await getCollection('runbooks')).map((r) => r.data);
---

<BaseLayout
  title="Response Runbooks — Shadow AI Defense"
  description={`${runbooks.length} graduated response runbooks for Shadow AI events. Decision trees, RACI, comms templates, metrics.`}
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <p class="text-sm font-medium text-accent-700">Runbooks</p>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">
      Response runbooks
    </h1>
    <p class="mt-3 text-ink-600 max-w-prose-wide">
      Graduated response procedures invoked when detections fire. Each
      includes phases (immediate / short-term / long-term), RACI, decision
      tree, comms templates, and metrics to capture.
    </p>

    <ol class="grid sm:grid-cols-2 gap-4 mt-10">
      {runbooks.map((r) => (
        <li>
          <a href={`/runbooks/${r.id}`} class="card-interactive block h-full">
            <div class="flex items-center justify-between gap-2 mb-1">
              <p class="font-mono text-xs text-ink-500">{r.id}</p>
              <span class={`badge ${r.severity === 'High' ? 'bg-risk-50 text-risk-700' : r.severity === 'Medium' ? 'bg-warn-50 text-warn-700' : 'bg-info-50 text-info-700'}`}>{r.severity}</span>
            </div>
            <h2 class="text-lg font-semibold text-ink-900">{r.title}</h2>
            <p class="text-sm text-ink-600 mt-2 line-clamp-3">{r.trigger}</p>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
