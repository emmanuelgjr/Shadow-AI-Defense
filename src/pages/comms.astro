---
import BaseLayout from '../layouts/BaseLayout.astro';

const comms = [
  { id: 'comms-all-employee-announcement', name: 'All-employee announcement: AI program launch', tag: 'v0.1' },
  { id: 'comms-all-employee-education', name: 'All-employee education: Responsible AI tool use', tag: 'v0.1' },
  { id: 'comms-manager-talking-points', name: 'Manager talking points', tag: 'v0.1' },
  { id: 'comms-individual-warning-first', name: 'Individual warning: first occurrence', tag: 'v0.1' },
  { id: 'comms-approved-tool-announcement', name: 'Approved-tool launch announcement', tag: 'v0.1' },
  { id: 'comms-individual-warning-repeat', name: 'Individual warning: repeat occurrence', tag: 'v0.2' },
  { id: 'comms-department-level-briefing', name: 'Department-level briefing (suspected widespread use)', tag: 'v0.2' },
  { id: 'comms-approved-pilot-announcement', name: 'Approved-pilot announcement', tag: 'v0.2' },
  { id: 'comms-incident-notification-sensitive-data-egress', name: 'Incident notification: sensitive data egress', tag: 'v0.2' },
  { id: 'comms-quarterly-program-update', name: 'Quarterly Shadow AI program update (risk committee)', tag: 'v0.2' },
];
---

<BaseLayout
  title="Employee Communications Templates — Shadow AI Defense"
  description="10 templates for Shadow AI program communications: announcement, education, manager talking points, warnings, incident notifications."
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <p class="text-sm font-medium text-accent-700">Comms</p>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">Employee communications templates</h1>
    <p class="mt-3 text-ink-600 max-w-prose-wide">
      Word and Markdown templates for every stage of the Shadow AI program.
      All CC-BY 4.0 — adapt with attribution.
    </p>

    <ul class="grid sm:grid-cols-2 gap-4 mt-10">
      {comms.map((c) => (
        <li class="card flex items-center justify-between gap-3">
          <div>
            <h2 class="text-base font-semibold text-ink-900">{c.name}</h2>
            <p class="text-xs text-ink-500 mt-0.5 font-mono">{c.id}</p>
          </div>
          {c.tag === 'v0.1' ? (
            <a href={`/templates/${c.id}.docx`} download class="btn btn-primary btn-sm">Download</a>
          ) : (
            <span class="badge-neutral">ships {c.tag}</span>
          )}
        </li>
      ))}
    </ul>

    <p class="mt-12 text-sm text-ink-500">
      In v0.1 the comms files in <code>/public/templates/</code> are stubs. The
      full text lands in v0.2 as each template passes review.
    </p>
  </section>
</BaseLayout>
