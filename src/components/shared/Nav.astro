---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}stack`, label: 'Stack' },
  { href: `${base}services`, label: 'Services' },
  { href: `${base}detections`, label: 'Detections' },
  { href: `${base}runbooks`, label: 'Runbooks' },
  { href: `${base}policy`, label: 'Policy' },
  { href: `${base}compliance`, label: 'Compliance' },
  { href: `${base}about`, label: 'About' },
];
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-white/80 backdrop-blur border-b border-ink-200">
  <div class="max-w-content mx-auto px-6 lg:px-8 flex items-center justify-between h-16">
    <a href={base} class="flex items-center gap-2 font-semibold text-ink-900">
      <span class="text-accent-700">Shadow</span><span>AI Defense</span>
    </a>
    <nav class="hidden md:flex items-center gap-5" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['text-sm font-medium hover:text-accent-700 transition-colors', pathname.startsWith(l.href) ? 'text-accent-700' : 'text-ink-700']}
        >{l.label}</a>
      ))}
    </nav>
    <a href="https://github.com/emmanuelgjr/Shadow-AI-Defense" class="btn btn-secondary btn-sm">GitHub</a>
  </div>
</header>
